{
  "name": "mazda-monorepo",
  "private": true,
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r dev",
    "lint": "pnpm -r --if-present lint",
    "test": "pnpm -r --if-present test",
    "check": "pnpm build && pnpm lint",
    "publish:packages": "pnpm -r --no-git-checks publish",
    "publish:packages:dry-run": "pnpm -r --no-git-checks publish --dry-run"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0"
  }
}
